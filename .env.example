# API
API_PORT=3000
API_PREFIX=api
CORS_ORIGIN="http://localhost:5173"

# Auth (JWT) — placeholder, replace before any real deployment
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="8h"

# Web
VITE_API_BASE_URL="http://localhost:3000/api"
