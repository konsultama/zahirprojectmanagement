# Database (matches docker-compose.yml; host port 5433 to avoid clashing with a local Postgres on 5432)
DATABASE_URL="postgresql://proj:proj_dev_password@localhost:5433/proj_db?schema=public"

# API
API_PORT=3000
API_PREFIX=api
CORS_ORIGIN="http://localhost:5173"

# Auth (JWT) — placeholder, replace before any real deployment
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="8h"

# Email (opsional) — jika SMTP_HOST kosong, email di-compose tapi tidak dikirim
# (dry-run, dicatat di log) sehingga dev berjalan tanpa mail server.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Zahir PM <no-reply@zahir.local>"

# Notifikasi channel (opsional) — semua dapat diatur juga dari menu Pengaturan.
# Telegram Bot API:
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""
# WhatsApp Cloud API (Meta):
# WHATSAPP_TOKEN=""
# WHATSAPP_PHONE_ID=""
# WHATSAPP_RECIPIENT=""
# WHATSAPP_API_VERSION="v21.0"

# Web
VITE_API_BASE_URL="http://localhost:3000/api"
