{
  "name": "zahir-project-management",
  "version": "0.1.0",
  "private": true,
  "description": "Aplikasi Project Management (PROJ) - PMBOK 5-stage project lifecycle module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm --filter \"./apps/*\" build",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @proj/api prisma:migrate",
    "db:seed": "pnpm --filter @proj/api prisma:seed",
    "db:studio": "pnpm --filter @proj/api prisma:studio",
    "lint": "pnpm --filter \"./apps/*\" lint",
    "format": "prettier --write \"apps/**/*.{ts,tsx,json}\"",
    "test": "pnpm --filter \"./apps/*\" test"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
